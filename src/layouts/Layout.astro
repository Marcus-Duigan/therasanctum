---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "A specialist-led integrative clinic in Singapore offering calm, considered care for complex chronic conditions and integrative oncology support." } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Thera Sanctum</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/branding/logo-icon.png" />
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>
<body>
  <slot />
</body>
</html>
