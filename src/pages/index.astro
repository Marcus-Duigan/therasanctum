---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Home" description="Thera Sanctum — specialist-led integrative clinic in Singapore. Calm, considered care for complex chronic conditions and integrative oncology support.">
  <Nav />

  <main>
    <!-- Hero -->
    <section class="hero" id="home">
      <div class="container hero-grid">
        <div>
          <div class="eyebrow">Specialist-led integrative clinic</div>
          <h1>Where your health feels complex, care should feel clear</h1>
          <p>A healing sanctuary for integrative care—bringing clarity, structure, and the missing pieces together so you can move forward with confidence.</p>
          <div class="cta-row">
            <a class="btn primary" href="#pathways">Find the right support</a>
            <a class="btn secondary" href="#approach">Learn about our approach</a>
          </div>
        </div>
        <div class="hero-art" aria-hidden="true">
          <img src="/images/herbs.jpg" alt="" />
        </div>
      </div>
    </section>

    <!-- Pathways -->
    <section class="section-alt" id="pathways">
      <div class="container">
        <div class="section-head" style="text-align: center; max-width:100%;">
          <h2>Two areas of clinical focus</h2>
        </div>
        <div class="pathway-grid">
          <article class="card">
            <div class="icon">❋</div>
            <h3>Autoimmune &amp; Chronic Conditions</h3>
            <p>Work with John Tang to address immune dysregulation, inflammation, and long-standing health concerns through a structured, root-cause approach.</p>
            <div class="cta-row">
              <a class="btn primary" href="/work-with-john">Work with John</a>
            </div>
          </article>
          <article class="card">
            <div class="card-body">
              <div>
                <div class="icon">✿</div>
                <h3>Oncology</h3>
                <p>Work with Wendy Ting for clear, structured support alongside your cancer care — helping you make sense of your options, strengthen your body’s terrain, and move forward with confidence.</p>
                <div class="cta-row">
                  <a class="btn primary" href="/work-with-wendy">Work with Wendy</a>
                </div>
              </div>
              <img src="/images/wendy.jpeg" alt="Wendy Ting" class="card-portrait" />
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- Approach -->
    <section id="approach">
      <div class="container two-col">
        <div>
          <h2>Care that meets complexity with clarity</h2>
          <p>Many people come to us feeling overwhelmed—by information, by decisions, or by the weight of managing a complex condition.</p>
          <p>Our role is not to add to that complexity, but to help you make sense of what's in front of you.</p>
          <p>We take a measured, personalised approach, working alongside your existing care in a way that is steady and considered.</p>
        </div>
        <div class="garden-image">
          <img src="/garden.jpg" alt="A lush garden with purple lavender, white daisies, and tropical plants" />
        </div>
      </div>
    </section>

    <!-- Who this is for / Our approach -->
    <section class="section-taupe">
      <div class="container two-col">
        <div>
          <h2>Who this is for</h2>
          <ul class="clean">
            <li>Complex or chronic health conditions</li>
            <li>Feeling overwhelmed or unsure where to start</li>
            <li>Seeking a more structured, personalised approach</li>
            <li>Open to integrating natural medicine with conventional care</li>
          </ul>
          <p class="small" style="margin-top:22px;">You don't need to have everything figured out.</p>
        </div>
        <div>
          <h2>Our approach</h2>
          <div class="approach-grid">
            <div class="approach-item">Evidence-informed, clinically grounded</div>
            <div class="approach-item">Personalised — no templates, no guesswork</div>
            <div class="approach-item">Informed by functional testing, not assuming</div>
            <div class="approach-item">Focused on underlying drivers, not just symptoms</div>
            <div class="approach-item">Thoughtful use of herbal and natural therapies, designed for tolerance</div>
            <div class="approach-item">Safe, considered and within practice scope</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about">
      <div class="container about-grid">
        <div class="about-art" aria-hidden="true"></div>
        <div>
          <div class="eyebrow">About Thera Sanctum</div>
          <h2>A specialist-led integrative clinic</h2>
          <p>Thera Sanctum supports individuals with complex chronic health conditions through calm, considered care.</p>
          <p>The clinic is structured around two distinct areas of focus: autoimmune conditions and integrative oncology support.</p>
          <p>Our approach is measured, evidence-informed, and designed to work alongside conventional care where appropriate.</p>
          <a class="btn secondary" href="/about">Learn more about us</a>
        </div>
      </div>
    </section>

    <!-- Testimonials carousel -->
    <section class="section-alt" id="testimonials">
      <div class="container">
        <div class="section-head" style="text-align:center; max-width:100%;">
          <div class="eyebrow">What patients say</div>
          <h2>Stories from people we've supported</h2>
        </div>
        <div class="carousel-wrap">
          <div class="carousel-inner" id="testimonialInner">
            <div class="carousel-slide">
              <span class="quote-mark">&ldquo;</span>
              <blockquote>After years of feeling dismissed and overwhelmed, John gave me something I hadn't had in a long time — a clear plan. He took the time to understand my full history and built a protocol that actually made sense. For the first time, I feel like I'm working with my body, not against it.</blockquote>
              <div class="carousel-author">
                <div class="avatar-initials" aria-hidden="true">S.L.</div>
                <div>
                  <p class="testimonial-name">S. Lim</p>
                  <p class="testimonial-label">Autoimmune patient</p>
                </div>
              </div>
            </div>
            <div class="carousel-slide">
              <span class="quote-mark">&ldquo;</span>
              <blockquote>Wendy was a calm, steady presence during one of the most frightening periods of my life. She helped me understand which supplements were safe alongside my treatment and what to prioritise. I never felt rushed or sold to — just genuinely supported.</blockquote>
              <div class="carousel-author">
                <div class="avatar-initials" aria-hidden="true">R.T.</div>
                <div>
                  <p class="testimonial-name">R. Tan</p>
                  <p class="testimonial-label">Integrative oncology support</p>
                </div>
              </div>
            </div>
            <div class="carousel-slide">
              <span class="quote-mark">&ldquo;</span>
              <blockquote>I came to Thera Sanctum having seen multiple specialists with no answers. John ran functional tests that finally revealed what was driving my fatigue. Within three months I had more energy than I'd had in years.</blockquote>
              <div class="carousel-author">
                <div class="avatar-initials" aria-hidden="true">M.C.</div>
                <div>
                  <p class="testimonial-name">M. Chong</p>
                  <p class="testimonial-label">Chronic fatigue patient</p>
                </div>
              </div>
            </div>
            <div class="carousel-slide">
              <span class="quote-mark">&ldquo;</span>
              <blockquote>Wendy supported my mother through her cancer treatment with such grace and knowledge. She liaised carefully with the oncology team and kept us informed every step of the way. The whole family felt held throughout the process.</blockquote>
              <div class="carousel-author">
                <div class="avatar-initials" aria-hidden="true">A.N.</div>
                <div>
                  <p class="testimonial-name">A. Ng</p>
                  <p class="testimonial-label">Family member of patient</p>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-dots" id="carouselDots"></div>
        <p style="text-align:center; margin-top:28px;">
          <a class="btn secondary" href="/testimonials">Read all testimonials</a>
        </p>
      </div>
    </section>

    <!-- CTA Band -->
    <section class="cta-band">
      <div class="container">
        <h2>Clarity over complexity. Care without overwhelm.</h2>
        <p>Book a consultation, or reach out if you're unsure where to start.</p>
        <div class="cta-row" style="justify-content:center;">
          <a class="btn primary" href="/booking">Book a consultation</a>
          <a class="btn secondary" href="/contact">General enquiry</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* Hero */
  .hero { padding: 72px 0 62px; }
  .hero-grid {
    display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center;
  }
  .hero p { max-width: 650px; font-size: 1.08rem; }

  /* Hero art */
  .hero-art {
    min-height: 540px; border-radius: 28px; box-shadow: var(--shadow);
    overflow: hidden;
  }
  .hero-art img {
    width: 100%; height: 100%; min-height: 540px; object-fit: cover; object-position: center; display: block;
  }

  /* Olive panel */
  .olive-panel {
    min-height: 420px; border-radius: 24px; background: linear-gradient(160deg, #f7f3ee 0%, #ede7de 100%);
    position: relative; overflow: hidden; box-shadow: var(--shadow);
  }
  .olive-panel::before, .olive-panel::after {
    content: ""; position: absolute; background: linear-gradient(90deg, rgba(111,140,128,0.95), rgba(143,167,154,0.95));
    border-radius: 999px; height: 5px; transform-origin: left center;
  }
  .olive-panel::before { width: 240px; right: 18%; top: 36%; transform: rotate(-18deg); }
  .olive-panel::after  { width: 220px; right: 10%; top: 55%; transform: rotate(20deg); }
  .olive-leaf, .olive-leaf2, .olive-leaf3, .olive-leaf4, .olive-leaf5 {
    position: absolute; width: 28px; height: 12px; background: linear-gradient(135deg, #90a896, #6d877a);
    border-radius: 100% 0 100% 0;
  }
  .olive-leaf  { right: 25%; top: 32%; transform: rotate(-12deg); }
  .olive-leaf2 { right: 34%; top: 30%; transform: rotate(-40deg); }
  .olive-leaf3 { right: 22%; top: 47%; transform: rotate(12deg); }
  .olive-leaf4 { right: 29%; top: 60%; transform: rotate(28deg); }
  .olive-leaf5 { right: 16%; top: 57%; transform: rotate(-8deg); }

  /* Oncology card with portrait */
  .card-body { display: flex; gap: 20px; align-items: flex-start; height: 100%; }
  .card-body > div:first-child { flex: 1; display: flex; flex-direction: column; gap: 14px; }
  .card-portrait {
    width: 110px; height: 140px; object-fit: cover; object-position: top center;
    border-radius: 12px; flex-shrink: 0; box-shadow: 0 4px 16px rgba(43,43,43,0.1);
  }

  @media (max-width: 980px) {
    .hero-art { min-height: 380px; }
    .card-portrait { width: 88px; height: 112px; }
  }
  @media (max-width: 640px) {
    .hero { padding-top: 44px; }
  }
</style>

<script>
  const inner = document.getElementById('testimonialInner') as HTMLElement | null;
  const dotsContainer = document.getElementById('carouselDots') as HTMLElement | null;
  if (inner && dotsContainer) {
    const slides = inner.querySelectorAll('.carousel-slide');
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Go to testimonial ${i + 1}`);
      dot.addEventListener('click', () => { goTo(i); resetTimer(); });
      dotsContainer.appendChild(dot);
    });

    function goTo(index: number) {
      current = index;
      inner!.style.transform = `translateX(-${100 * current}%)`;
      dotsContainer!.querySelectorAll('.carousel-dot').forEach((d, i) =>
        d.classList.toggle('active', i === current)
      );
    }

    function advance() { goTo((current + 1) % slides.length); }

    function resetTimer() { clearInterval(timer); timer = setInterval(advance, 4500); }

    inner.parentElement?.addEventListener('mouseenter', () => clearInterval(timer));
    inner.parentElement?.addEventListener('mouseleave', resetTimer);

    resetTimer();
  }
</script>
